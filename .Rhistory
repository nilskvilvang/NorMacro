query = query
)
lonn_nivaa <- lonn_raw |>
dplyr::filter(ContentsCode == "Årslønn, påløpt (1 000 kr)") |>
dplyr::select(Tid, value) |>
dplyr::rename(
Aar = Tid,
Lonn = value
)
lonn_vekst <- lonn_raw |>
dplyr::filter(
ContentsCode == "Årslønn, påløpt. Endring fra året før i prosent"
) |>
dplyr::select(Tid, value) |>
dplyr::rename(
Aar = Tid,
Lonnvekst = value
)
lonn_nivaa |>
dplyr::left_join(lonn_vekst, by = "Aar") |>
dplyr::mutate(
Aar = as.integer(Aar),
Lonn = as.numeric(Lonn),
Lonnvekst = as.numeric(Lonnvekst)
) |>
dplyr::arrange(Aar)
}
