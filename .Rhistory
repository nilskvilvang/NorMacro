get_sysselsatte <- function(){
query <- list(
Alder = "15-74",
Kjonn = c("2", "1"),
ContentsCode = "Personer",
Tid = "*"
)
sysselsatte_raw <- ssb_get(
url = "https://data.ssb.no/api/v0/no/table/al/al06/aku/SBMENU9726/SysselAKUAar",
query = query
)
sysselsatte_raw |>
dplyr::rename(
Aar = ar,
Kjonn = kjonn,
Sysselsatte = personer_1_000_personer
) |>
dplyr::mutate(
Aar = readr::parse_number(Aar),
Sysselsatte = as.numeric(Sysselsatte)
) |>
dplyr::group_by(Aar) |>
dplyr::summarise(
Sysselsatte = sum(Sysselsatte, na.rm = TRUE) * 1000,
.groups = "drop"
) |>
dplyr::arrange(Aar)
}
sysselsatte_raw <- ssb_get(
