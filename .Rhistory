)
create_international_derived_variables <- function(data) {
data |>
dplyr::arrange(Land, Aar) |>
dplyr::group_by(Land) |>
dplyr::mutate(
Inflasjon = (HICP / dplyr::lag(HICP) - 1) * 100,
Befolkningsvekst = (Befolkning / dplyr::lag(Befolkning) - 1) * 100,
BNP_lopende_per_innbygger = BNP_lopende / Befolkning
) |>
dplyr::ungroup()
}
group_by(Land)
hicp <- get_hicp()
population <- get_population()
gdp <- get_gdp()
international_test <- hicp |>
dplyr::full_join(population, by = c("Aar", "Land")) |>
dplyr::full_join(gdp, by = c("Aar", "Land")) |>
create_international_derived_variables()
international_test |>
dplyr::select(
Aar,
Land,
HICP,
Inflasjon,
Befolkning,
Befolkningsvekst,
BNP_lopende,
BNP_lopende_per_innbygger
) |>
dplyr::filter(Land == "NO") |>
print(n = 20)
international_test |>
dplyr::group_by(Land) |>
dplyr::summarise(
first_year = min(Aar),
last_year = max(Aar),
first_inflation_year = min(Aar[!is.na(Inflasjon)]),
.groups = "drop"
)
create_international_derived_variables <- function(data) {
