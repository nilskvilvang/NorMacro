Lonnvekst = arslonn_palopt_endring_fra_aret_for_i_prosent
) |>
dplyr::mutate(
Aar = as.integer(Aar),
Lonn = as.numeric(Lonn),
Lonnvekst = as.numeric(Lonnvekst)
) |>
dplyr::arrange(Aar)
}
