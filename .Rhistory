category_variables("Konjunkturindikatorer")
category_variables <- function(category){
metadata <- get_metadata()
result <- metadata |>
dplyr::filter(Kategori == category) |>
dplyr::select(
Variabel,
Type,
Beskrivelse,
Enhet,
Startaar,
Sluttaar,
Kilde
) |>
dplyr::arrange(Type, Variabel)
if(nrow(result) == 0){
message("Ingen variabler funnet for kategori: ", category)
return(invisible(result))
}
result
}
category_variables("Konjunkturindikatorer")
category_variables("Produksjon og aktivitet")
plot_series <- function(variable, data = NULL){
if(is.null(data)){
data <- get_normacro()
}
if(!variable %in% names(data)){
stop("Fant ikke variabelen i datasettet: ", variable)
}
plot_data <- data |>
dplyr::select(Aar, Verdi = dplyr::all_of(variable)) |>
dplyr::filter(!is.na(Verdi))
ggplot2::ggplot(plot_data, ggplot2::aes(x = Aar, y = Verdi)) +
ggplot2::geom_line() +
ggplot2::labs(
title = variable,
x = NULL,
y = NULL
) +
ggplot2::theme_minimal()
}
plot_series("BNP_Fastland")
plot_series("Rentekurve") +
ggplot2::labs(title = "Rentekurve i Norge")
plot_series("BNP_Fastland")
