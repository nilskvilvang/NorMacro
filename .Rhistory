Tabell = NA_character_,
Enhet = NA_character_,
Frekvens = "Årlig",
Startaar = NA_real_,
Sluttaar = NA_real_,
Funksjon = NA_character_,
Kommentar = NA_character_,
Omraade = "Internasjonal"
)
