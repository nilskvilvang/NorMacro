is.na(start_value) |
start_value == 0,
NA_real_,
(end_value / start_value - 1) * 100
)
)
}
)
result |>
dplyr::left_join(
metadata |>
dplyr::select(
Variabel,
Kategori,
Beskrivelse,
Enhet
),
by = "Variabel"
) |>
dplyr::select(
Variabel,
Kategori,
Beskrivelse,
Enhet,
dplyr::everything()
)
}
compare_periods(
variables = c(
"BNP_Fastland",
"Privat_konsum",
"Industriproduksjon"
),
start_year = 2010,
end_year = 2025
)
