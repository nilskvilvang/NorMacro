Aar = as.integer(format(.data$time, "%Y")),
Land = .data$geo,
Statsrente_10aar = .data$values
) |>
dplyr::filter(!is.na(.data$Statsrente_10aar)) |>
dplyr::arrange(.data$Land, .data$Aar)
}
