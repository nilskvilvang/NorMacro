coverage() |>
dplyr::filter(Variabel %in% c(
"Styringsrente",
"Statsrente_10aar",
"Rentekurve"
))
leading_indicators <- function(data = NULL){
if(is.null(data)){
data <- suppressMessages(get_normacro())
}
indicators <- c(
"Aar",
"Industriproduksjon",
"Byggeaktivitet",
"Tjenesteproduksjon",
"Detaljhandel",
"Konjunkturindikator",
"Kapasitetsutnytting",
"Ressursknapphet",
"Ordrebeholdning",
"Arbledighetsrate_NAV",
"Styringsrente",
"Pengemarkedsrente_3mnd",
"Statsrente_10aar",
"Rentekurve"
)
existing <- intersect(indicators, names(data))
result <- data |>
dplyr::select(dplyr::all_of(existing))
indicator_cols <- setdiff(names(result), "Aar")
result |>
dplyr::filter(
rowSums(!is.na(dplyr::across(dplyr::all_of(indicator_cols)))) > 0
)
}
leading <- leading_indicators()
head(leading)
tail(leading)
testthat::test_dir("tests/testthat")
