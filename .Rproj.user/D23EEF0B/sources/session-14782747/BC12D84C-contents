
get_bnp_lopende <- function(){
  
  query <- list(
    ContentsCode = "BNP",
    Tid = "*"
  )
  
  bnp <- ssb_get(
    url = "https://data.ssb.no/api/v0/no/table/nk/nk03/knr/SBMENU5140/NRbnp",
    query = query
  )
  
  names(bnp) <- c("Aar", "BNP_lopende")
  
  bnp |>
    dplyr::mutate(
      Aar = as.integer(Aar),
      BNP_lopende = readr::parse_number(as.character(BNP_lopende))
    ) |>
    dplyr::arrange(Aar)
}
